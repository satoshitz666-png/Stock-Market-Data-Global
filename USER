    <script>
        // --- 1. Language Configuration ---
        const translations = {
            en: {
                nav_dashboard: "Dashboard",
                nav_prompt_engine: "Prompt Engine",
                nav_files: "My Files",
                nav_reports: "Reports",
                nav_prospectus: "Prospectus Data",
                nav_recommendations: "AI Recommendations",
                nav_markets: "Top 10 Markets",
                nav_portfolio: "Portfolio & P&L",
                nav_rebalancing: "Rebalancing",
                nav_credits: "Credits & Payment",
                stat_prompts_used: "Total Prompts Used",
                stat_remaining_credits: "Remaining Credits",
                stat_files_uploaded: "Files Uploaded",
                stat_reports_gen: "Reports Generated",
                chart_portfolio_title: "Portfolio Performance (P&L)",
                recent_activity: "Recent Activity",
                prompt_engine_title: "AI Stock Analysis Engine",
                label_prompt_input: "Prompt Input",
                label_attach_docs: "Attach Documents",
                upload_text: "Drag & drop files here or click to browse",
                label_output_format: "Output Format",
                label_language: "Analysis Language",
                label_complexity: "Complexity",
                btn_run_analysis: "Run Analysis",
                prospectus_title: "Listed Companies (Prospectus Data)",
                markets_title: "Top 10 Global Markets",
                rebalancing_title: "AI Rebalancing Strategy"
            },
            id: {
                nav_dashboard: "Dasbor",
                nav_prompt_engine: "Mesin Prompt",
                nav_files: "File Saya",
                nav_reports: "Laporan",
                nav_prospectus: "Data Prospektus",
                nav_recommendations: "Rekomendasi AI",
                nav_markets: "10 Pasar Teratas",
                nav_portfolio: "Portofolio & L/R",
                nav_rebalancing: "Penyeimbangan Ulang",
                nav_credits: "Kredit & Pembayaran",
                stat_prompts_used: "Total Prompt Digunakan",
                stat_remaining_credits: "Sisa Kredit",
                stat_files_uploaded: "File Diunggah",
                stat_reports_gen: "Laporan Dibuat",
                chart_portfolio_title: "Kinerja Portofolio (L/R)",
                recent_activity: "Aktivitas Terbaru",
                prompt_engine_title: "Mesin Analisa Saham AI",
                label_prompt_input: "Input Prompt",
                label_attach_docs: "Lampirkan Dokumen",
                upload_text: "Seret & lepas file di sini atau klik untuk cari",
                label_output_format: "Format Output",
                label_language: "Bahasa Analisa",
                label_complexity: "Kompleksitas",
                btn_run_analysis: "Jalankan Analisa",
                prospectus_title: "Perusahaan Tercatat (Data Prospektus)",
                markets_title: "10 Pasar Global Teratas",
                rebalancing_title: "Strategi Penyeimbangan Ulang AI"
            }
        };

        let currentLang = 'en';

        function setLanguage(lang) {
            currentLang = lang;
            document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (translations[lang][key]) {
                    el.textContent = translations[lang][key];
                }
            });
        }

        // --- 2. Navigation ---
        function navigate(sectionId, navElement) {
            // Hide all sections
            document.querySelectorAll('.page-section').forEach(sec => sec.classList.remove('active'));
            // Show target section
            document.getElementById(sectionId).classList.add('active');
            
            // Update Nav Active State
            document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
            if(navElement) navElement.classList.add('active');

            // Update Header Title
            const titleKey = navElement.getAttribute('data-i18n') || sectionId;
            document.getElementById('page-title').textContent = translations[currentLang][titleKey] || titleKey;
        }

        // --- 3. File Upload Simulation ---
        const dropZone = document.getElementById('drop-zone');
        const fileInput = document.getElementById('file-input');
        const fileList = document.getElementById('file-list');

        dropZone.addEventListener('click', () => fileInput.click());

        fileInput.addEventListener('change', (e) => {
            handleFiles(e.target.files);
        });

        function handleFiles(files) {
            fileList.innerHTML = '';
            Array.from(files).forEach(file => {
                const tag = document.createElement('div');
                tag.style.cssText = 'background: var(--accent-blue-light); color: var(--accent-blue); padding: 5px 10px; border-radius: 4px; font-size: 12px; display: flex; align-items: center; gap: 5px;';
                tag.innerHTML = `<i class="fas fa-file"></i> ${file.name}`;
                fileList.appendChild(tag);
            });
        }

        // --- 4. Run Analysis Simulation ---
        function runAnalysis() {
            const btn = document.querySelector('.btn-primary');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Analyzing...';
            btn.disabled = true;

            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.disabled = false;
                alert('Analysis Complete! Report generated in PDF & Excel.');
                // Switch to reports or show a notification
            }, 2000);
        }

        // --- 5. Payment Modal ---
        function openPaymentModal() {
            document.getElementById('payment-modal').classList.add('active');
        }

        function closePaymentModal() {
            document.getElementById('payment-modal').classList.remove('active');
        }

        function selectPayment(el) {
            document.querySelectorAll('.payment-option').forEach(opt => opt.classList.remove('selected'));
            el.classList.add('selected');
        }

        // --- 6. Charts Initialization (Chart.js) ---
        document.addEventListener('DOMContentLoaded', () => {
            // Portfolio Chart
            const ctxPortfolio = document.getElementById('portfolioChart').getContext('2d');
            new Chart(ctxPortfolio, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [{
                        label: 'Portfolio Value ($)',
                        data: [100000, 105000, 102000, 110000, 115000, 142500],
                        borderColor: '#3b82f6',
                        backgroundColor: 'rgba(59, 130, 246, 0.1)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: false, grid: { color: '#f0f4f8' } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // Allocation Chart
            const ctxAlloc = document.getElementById('allocationChart').getContext('2d');
            new Chart(ctxAlloc, {
                type: 'doughnut',
                data: {
                    labels: ['Stocks', 'Cash', 'Crypto'],
                    datasets: [{
                        data: [88, 8, 4],
                        backgroundColor: ['#3b82f6', '#22c55e', '#f59e0b'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'right' }
                    }
                }
            });
        });

    </script>
